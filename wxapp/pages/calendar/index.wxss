.type-scroll {
  width: 100%;
  margin-top: 18rpx;
}

.type-strip {
  display: inline-flex;
  gap: 12rpx;
  padding-bottom: 6rpx;
}

.type-chip {
  display: inline-flex;
  align-items: center;
  box-sizing: border-box;
  min-width: 168rpx;
  padding: 15rpx 16rpx;
  border: 1rpx solid #dbe5f0;
  border-radius: 14rpx;
  background: #ffffff;
  box-shadow: none;
  transition: transform 120ms ease, opacity 120ms ease;
}

.type-chip:active {
  opacity: 0.84;
  transform: scale(0.98);
}

.type-chip.active {
  border-color: #0f5ce8;
  background: #eff6ff;
}

.type-label {
  color: #0f172a;
  font-size: 23rpx;
  font-weight: 800;
  white-space: nowrap;
}

.type-count {
  margin-top: 3rpx;
  color: #64748b;
  font-size: 20rpx;
  white-space: nowrap;
}

.section-card {
  overflow: hidden;
}

.section-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 8rpx;
}

.section-desc {
  margin-top: -8rpx;
  margin-bottom: 8rpx;
  line-height: 1.45;
}

.event-group {
  margin-bottom: 4rpx;
  color: #0f5ce8;
  font-size: 22rpx;
  font-weight: 800;
}

.event {
  margin-top: 14rpx;
  padding: 18rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 14rpx;
  background: #ffffff;
  box-shadow: none;
  transition: transform 120ms ease, opacity 120ms ease;
}

.event:last-child {
  border-bottom: 0;
}

.event-ended {
  opacity: 0.7;
}

.event-tappable {
  border-radius: 16rpx;
}

.event-tappable:active {
  opacity: 0.86;
  transform: scale(0.99);
}

.event-type {
  color: #0f5ce8;
  font-size: 22rpx;
  font-weight: 800;
}

.event-type-line {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.event-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 16rpx;
}

.event-badges {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 8rpx;
  flex-shrink: 0;
}

.event-title {
  margin-top: 6rpx;
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 750;
  line-height: 1.35;
}

.status-pill {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.status-ended {
  background: #f1f5f9;
  color: #64748b;
}

.status-upcoming {
  background: #eef6ff;
  color: #0f5ce8;
}

.status-soon,
.status-ending {
  background: #fef3c7;
  color: #b45309;
}

.status-active {
  background: #e8f8ef;
  color: #087443;
}

.event-more-icon {
  flex-shrink: 0;
  width: 30rpx;
  height: 30rpx;
  opacity: 0.82;
}

.format-pill {
  display: inline-flex;
  margin-top: 12rpx;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(239, 243, 248, 0.72);
  color: #334155;
  font-size: 22rpx;
}

.event-desc {
  margin-top: 10rpx;
  color: #475569;
  font-size: 24rpx;
  line-height: 1.45;
}

.event-action-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 120;
  display: flex;
  align-items: flex-end;
  padding: 24rpx;
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(15, 23, 42, 0.28);
}

.event-action-panel {
  box-sizing: border-box;
  width: 100%;
  overflow: hidden;
  border: 1rpx solid #dbe5f0;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 42rpx rgba(15, 23, 42, 0.16);
}

.event-action-head {
  padding: 24rpx 26rpx 18rpx;
  border-bottom: 1rpx solid #eef2f7;
}

.event-action-title {
  margin-bottom: 6rpx;
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.event-action-row {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 18rpx;
  width: 100%;
  min-height: 92rpx;
  margin: 0;
  padding: 0 26rpx;
  border: 0;
  border-bottom: 1rpx solid #eef2f7;
  border-radius: 0;
  background: #ffffff;
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.2;
  text-align: left;
}

.event-action-row::after {
  border: 0;
}

.event-action-row.disabled {
  color: #94a3b8;
}

.event-action-hover,
.event-action-row:active {
  background: #f8fafc;
}

.event-action-icon {
  flex-shrink: 0;
  width: 34rpx;
  height: 34rpx;
}

.share-row {
  position: relative;
  justify-content: flex-start;
  text-align: left;
}

.action-share-trigger {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
  min-height: 0;
  margin: 0;
  padding: 0;
  border: 0;
  border-width: 0;
  border-color: transparent;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
  color: transparent;
  font-size: 0;
  line-height: 0;
  outline: 0;
  appearance: none;
}

.action-share-trigger::after {
  border: 0;
}

.event-action-cancel {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  color: #64748b;
  font-size: 28rpx;
  font-weight: 700;
}

.event-action-cancel:active {
  background: #f8fafc;
}

.event-share-canvas {
  position: fixed;
  left: -9999rpx;
  bottom: -9999rpx;
  width: 600px;
  height: 480px;
  pointer-events: none;
}

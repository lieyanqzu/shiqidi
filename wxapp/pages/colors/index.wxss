.date-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.query-strip {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin: 22rpx 0;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #dbe5f0;
}

.query-main {
  min-width: 0;
  flex: 1;
}

.query-title {
  min-width: 0;
  color: #111827;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.25;
  overflow-wrap: anywhere;
}

.query-meta {
  margin-top: 8rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.4;
}

.query-actions {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  gap: 8rpx;
}

.icon-action {
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  border: 1rpx solid #cfdbea;
  border-radius: 12rpx;
  background: #ffffff;
  transition: transform 120ms ease, opacity 120ms ease;
}

.icon-action:active {
  opacity: 0.82;
  transform: scale(0.94);
}

.primary-icon-action {
  border-color: #0f5ce8;
  background: #0f5ce8;
}

.action-icon {
  width: 34rpx;
  height: 34rpx;
}

.chevron-icon {
  transform: rotate(90deg);
  transition: transform 160ms ease;
}

.chevron-icon.expanded {
  transform: rotate(-90deg);
}

.icon-action.loading .action-icon {
  animation: colors-spin 900ms linear infinite;
}

@keyframes colors-spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.control-panel {
  margin-bottom: 18rpx;
}

.switch-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #dbe5f0;
}

.switch-copy {
  min-width: 0;
  flex: 1;
}

.switch-copy .label {
  margin-bottom: 4rpx;
}

.switch-hint {
  color: #667085;
  font-size: 22rpx;
  line-height: 1.35;
}

.loading-banner {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin: 0 0 18rpx;
  padding: 16rpx 18rpx;
  border: 1rpx solid #bfdbfe;
  border-radius: 12rpx;
  background: #eff6ff;
  color: #0f5ce8;
  font-size: 24rpx;
  font-weight: 850;
}

.loading-spinner {
  width: 30rpx;
  height: 30rpx;
  border: 3rpx solid #bfdbfe;
  border-top-color: #0f5ce8;
  border-radius: 999rpx;
  animation: colors-spin 900ms linear infinite;
}

.color-result-card {
  padding-bottom: 10rpx;
}

.result-head {
  margin-bottom: 8rpx;
}

.result-head .section-title {
  margin-bottom: 0;
}

.color-group {
  padding: 18rpx 0 4rpx;
  border-top: 1rpx solid #e2e8f0;
}

.color-group:first-of-type {
  border-top: 0;
}

.group-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.group-title {
  color: #111827;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.25;
}

.group-meta {
  flex-shrink: 0;
  color: #667085;
  font-size: 22rpx;
  font-weight: 800;
}

.color-row-list {
  display: grid;
  gap: 8rpx;
}

.color-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-width: 0;
  padding: 14rpx 0;
  border-top: 1rpx solid #f1f5f9;
}

.color-row:first-child {
  border-top: 0;
}

.color-main {
  min-width: 0;
  flex: 1;
}

.color-title-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.color-symbols {
  display: inline-flex;
  align-items: center;
  gap: 3rpx;
  flex-shrink: 0;
}

.color-symbol {
  width: 26rpx;
  min-width: 26rpx;
  height: 26rpx;
  padding: 0;
  font-size: 19rpx;
}

.color-title {
  min-width: 0;
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 850;
  line-height: 1.25;
  overflow-wrap: anywhere;
}

.color-raw {
  margin-top: 5rpx;
  color: #667085;
  font-size: 22rpx;
  line-height: 1.3;
  overflow-wrap: anywhere;
}

.color-stats {
  flex-shrink: 0;
  min-width: 130rpx;
  text-align: right;
}

.color-rate {
  color: #0f5ce8;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.2;
}

@media (prefers-reduced-motion: reduce) {
  .icon-action,
  .chevron-icon {
    transition: none;
  }

  .icon-action.loading .action-icon,
  .loading-spinner {
    animation: none;
  }
}

.share-canvas {
  position: fixed;
  left: -9999rpx;
  bottom: -9999rpx;
  width: 600px;
  height: 480px;
}

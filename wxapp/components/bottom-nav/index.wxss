.bottom-nav-root {
  display: block;
}

.nav-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 68;
  background: rgba(15, 23, 42, 0.16);
}

.nav-panel {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 70;
}

.nav-drawer {
  padding: 22rpx 26rpx 18rpx;
  border-top: 1rpx solid #dbe5f0;
  background: #ffffff;
  box-shadow: 0 -12rpx 30rpx rgba(15, 23, 42, 0.08);
}

.drawer-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.drawer-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.2;
}

.drawer-close {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border: 1rpx solid #dbe5f0;
  border-radius: 12rpx;
  background: #ffffff;
}

.drawer-close:active,
.nav-menu-item:active,
.nav-item:active {
  opacity: 0.86;
  transform: scale(0.97);
}

.drawer-close-icon {
  width: 30rpx;
  height: 30rpx;
}

.nav-menu-list {
  display: grid;
  gap: 1rpx;
  overflow: hidden;
  border: 1rpx solid #dbe5f0;
  border-radius: 14rpx;
  background: #dbe5f0;
}

.nav-menu-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 82rpx;
  padding: 0 18rpx;
  background: #ffffff;
  transition: transform 120ms ease, opacity 120ms ease;
}

.nav-menu-item.active {
  background: #eff6ff;
}

.menu-icon-cell {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
}

.menu-icon {
  width: 34rpx;
  height: 34rpx;
}

.menu-title {
  flex: 1;
  min-width: 0;
  color: #111827;
  font-size: 27rpx;
  font-weight: 850;
  line-height: 1.2;
}

.nav-menu-item.active .menu-title {
  color: #0f5ce8;
}

.menu-cue {
  width: 26rpx;
  height: 26rpx;
  transform: rotate(0deg);
}

.nav-shell {
  padding: 8rpx 18rpx;
  padding-bottom: calc(8rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(8rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #dbe5f0;
  background: #ffffff;
}

.nav-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  align-items: center;
  min-height: 92rpx;
}

.nav-item {
  display: flex;
  min-width: 0;
  height: 84rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 5rpx;
  color: #111827;
  transition: transform 120ms ease, opacity 120ms ease;
}

.nav-icon {
  width: 42rpx;
  height: 42rpx;
}

.nav-label {
  max-width: 100%;
  color: inherit;
  font-size: 21rpx;
  font-weight: 850;
  line-height: 1;
  overflow-wrap: anywhere;
}

.nav-item.active,
.nav-item.open {
  color: #0f5ce8;
}

@media (prefers-reduced-motion: reduce) {
  .drawer-close,
  .nav-menu-item,
  .nav-item {
    transition: none;
  }
}
